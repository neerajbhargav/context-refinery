{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-schema/v2/schema.json",
  "productName": "ContextRefinery",
  "version": "0.1.0",
  "identifier": "com.contextrefinery.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ContextRefinery — Context Orchestration Engine",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8741 http://127.0.0.1:8741; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/context-refinery-api"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    },
    "shortDescription": "AI-powered context orchestration engine",
    "longDescription": "ContextRefinery transforms codebases into LLM-optimized prompts using hybrid retrieval, cross-encoder reranking, and multi-agent refinement. Supports Google Gemini, OpenAI, Anthropic, and local Ollama models.",
    "copyright": "Copyright 2025 ContextRefinery",
    "category": "DeveloperTool",
    "publisher": "ContextRefinery"
  }
}
